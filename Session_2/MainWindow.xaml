<Window x:Class="Session_2_Lommeregner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Session_2_Lommeregner"
        mc:Ignorable="d"
        Title="Lommeregner" Height="450" Width="300"
        Background="Black"
        Foreground="White">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="DisplayText"
                   Grid.Row="0"
                   Text="0"
                   FontSize="36"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Margin="10"
                   Background="Black"
                   Foreground="White"/>

        <UniformGrid Grid.Row="1" Columns="4">
            <Button Content="7" Click="Number_Click" Background="White" FontSize="20"/>
            <Button Content="8" Click="Number_Click" Background="White" FontSize="20"/>
            <Button Content="9" Click="Number_Click" Background="White" FontSize="20"/>
            <Button Content="÷" Click="Operator_Click" Background="Orange" FontSize="20" Foreground="White" FontWeight="Bold"/>

            <Button Content="4" Click="Number_Click" Background="White" FontSize="20"/>
            <Button Content="5" Click="Number_Click" Background="White" FontSize="20"/>
            <Button Content="6" Click="Number_Click" Background="White" FontSize="20"/>
            <Button Content="×" Click="Operator_Click" Background="Orange" FontSize="20" Foreground="White" FontWeight="Bold"/>

            <Button Content="1" Click="Number_Click" Background="White" FontSize="20"/>
            <Button Content="2" Click="Number_Click" Background="White" FontSize="20"/>
            <Button Content="3" Click="Number_Click" Background="White" FontSize="20"/>
            <Button Content="-" Click="Operator_Click" Background="Orange" FontSize="20" Foreground="White" FontWeight="Bold"/>

            <Button Content="0" Click="Number_Click" Background="White" FontSize="20"/>
            <Button Content="C" Click="Clear_Click" Background="LightGray" FontSize="20"/>
            <Button Content="=" Click="Equals_Click" Background="Orange" FontSize="20" Foreground="White" FontWeight="Bold"/>
            <Button Content="+" Click="Operator_Click" Background="Orange" FontSize="20" Foreground="White" FontWeight="Bold"/>
        </UniformGrid>
    </Grid>
</Window>